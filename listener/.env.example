# MQTT broker (same as ESP32 .env)
MQTT_HOST=your-cluster.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_USERNAME=
MQTT_PASSWORD=

# Database — local SQLite (shared with monitor) or Turso remote
DATABASE_URL=file:../monitor/data/gardener.db
TURSO_AUTH_TOKEN=

# Which devices to listen to (comma-separated, empty = all)
# LISTENER_DEVICE_IDS=balcony,kitchen
