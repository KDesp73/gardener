# Database — use local SQLite for dev, libsql://your-db.turso.io for production
DATABASE_URL=file:./data/gardener.db

# Turso authentication (only needed for remote Turso databases)
# TURSO_AUTH_TOKEN=

# MQTT broker for publishing config changes (TCP)
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# MQTT WebSocket for browser real-time data
NEXT_PUBLIC_MQTT_WS_URL=wss://your-cluster-id.s1.eu.hivemq.cloud:8884/mqtt
NEXT_PUBLIC_MQTT_USERNAME=
NEXT_PUBLIC_MQTT_PASSWORD=
